# Falconry AI Backend — environment variables
# Copy this file to .env and fill in your values.

# API key required on every request (X-API-Key header)
FALCONRY_API_KEY=your_falconry_api_key_here

# Groq API key — powers the CrewAI agents
# Get one free at https://console.groq.com
GROQ_API_KEY=
# Serper API key — enables internet search for the Remediation Advisor agent
# Get one free at https://serper.dev
# Optional: if omitted the remediation agent runs without web search
SERPER_API_KEY=your_serper_api_key_here
