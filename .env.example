# Falconry AI Backend — environment variables
# Copy this file to .env and fill in your values.

# API key required on every request (X-API-Key header)
FALCONRY_API_KEY=your_falconry_api_key_here

# Groq API key — powers the CrewAI agents
# Get one free at https://console.groq.com
GROQ_API_KEY=
# Serper API key — enables internet search for the Remediation Advisor agent
# Get one free at https://serper.dev
# Optional: if omitted the remediation agent runs without web search
SERPER_API_KEY=your_serper_api_key_here

# ── Object Store (S3 / compatible) ────────────────────────────────────────────
# Optional — when set, generated files are uploaded and a public URL is returned
# in the X-File-URL response header. Omit these to skip object store uploads.
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_REGION=us-east-1
# Optional overrides:
# AWS_S3_ENDPOINT_URL=https://... (for MinIO, Cloudflare R2, DigitalOcean Spaces)
# AWS_S3_PUBLIC_BASE_URL=https://cdn.example.com
